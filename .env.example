=== GCP Shared ===
GCP_PROJECT_ID=hometown-success-engine # The Google Cloud project ID
GCP_LOCATION=us-central1 # Default GCP region
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json # Path to service account JSON (local dev only)

=== Backend ===
PORT=8080 # Default port for local dev, Cloud Run sets this automatically
FRONTEND_ORIGIN=* # * for local dev, the Firebase Hosting URL in prod
VERTEX_AI_LOCATION=us-central1 # Region for Vertex AI calls
GEMINI_MODEL=gemini-2.5-flash # Gemini model used by the backend

=== Pipeline ===
BIGQUERY_DATASET=athlete_data # Target BigQuery dataset
FIRESTORE_DATABASE=(default) # Target Firestore database name
GCS_BUCKET=your-gcs-bucket-name # The Cloud Storage bucket name
GEMINI_MODEL=gemini-2.5-flash # Same as backend, can be different model for extraction

=== Frontend ===
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here # From GCP console, Maps JavaScript API
VITE_BACKEND_URL=http://localhost:8080 # http://localhost:8080 for dev, Cloud Run URL in prod