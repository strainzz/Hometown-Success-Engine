# Example local environment values.
# Copy values into your shell, Cloud Run environment, or local .env tooling.
# Do not commit real API keys, service account files, or generated .env files.

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GCP_PROJECT_ID=your-google-cloud-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/local-service-account.json

# Gemini / Vertex AI
GEMINI_LOCATION=global
GEMINI_LIVE_LOCATION=us-central1
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_VOICE_NAME=Kore

# Backend
PORT=8080
FRONTEND_ORIGIN=*

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_MAPS_MAP_ID=your-google-maps-map-id

# Optional pipeline settings
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
USER_AGENT="HometownSuccessEngine/0.1.0 (contact@example.com)"
