# .gcloudignore — controls what gets uploaded to Cloud Build
# This OVERRIDES .gitignore for gcloud uploads.
# IMPORTANT: pipeline/clustered/athletes.json IS gitignored for NIL safety on GitHub,
# but we MUST upload it to Cloud Build so the container can read it.

# Python
__pycache__/
*.pyc
.venv/
venv/
pipeline/.venv/

# Node
node_modules/
frontend/dist/
frontend/.vite/
frontend/node_modules/

# Git/IDE
.git/
.vscode/
.idea/
.firebaserc
.firebase/
.playwright-cli/

# OS
.DS_Store
Thumbs.db

# Secrets/local env
.env
.env*
frontend/.env
frontend/.env*
*.pem
*.key
*service*account*.json
*ServiceAccount*.json

# Pipeline raw data (large, not needed in container)
pipeline/raw_data/
pipeline/cache/
pipeline/geocoded/
pipeline/normalized/
pipeline/compliance/
backend/pipeline_data/
pipeline/clustered/athletes.json

# Local backups/artifacts
frontend/src/hometown-hub-map.ts.broken
frontend/vite-*.log

# pipeline/clustered/athletes_public.json is the sanitized deploy/runtime file.
